@model SkateSpotter.Presentation.Models.LoginViewModel

@{
    ViewData["Title"] = "Inloggen";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2 class="mb-4">Inloggen</h2>

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label asp-for="Username" class="form-label">Username</label>
                <input asp-for="Username" class="form-control" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label">Wachtwoord</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <button type="submit" class="btn btn-primary w-100">Inloggen</button>
        </form>

        <p class="mt-3 text-center">
            Nog geen account? <a asp-action="Register">Registreer hier</a>
        </p>
    </div>
</div>