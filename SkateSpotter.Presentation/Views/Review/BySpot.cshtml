@model IEnumerable<SkateSpotter.Data.Models.Review>

<h1>Reviews voor deze spot</h1>

@if (!Model.Any())
{
    <p>Er zijn nog geen reviews voor deze spot.</p>
}
else
{
    <ul>
        @foreach (var r in Model)
        {
            <li>
                <strong>@r.Username</strong> — Rating: @r.Rating<br />
                @r.Comment
            </li>
        }
    </ul>
}
